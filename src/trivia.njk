---
pageKey: trivia
permalink: /trivia/
---
{% extends "layouts/base.njk" %}

{% block pageTitle %}{{ pagesMeta.trivia.title }}{% endblock %}
{% block pageDescription %}{{ pagesMeta.trivia.meta_description }}{% endblock %}

{% block extraHead %}
  <!-- Quiz Embed Web Component -->
  <script src="https://cdn.jsdelivr.net/npm/@gstreet-ops/quiz-embed@latest/dist/quiz-embed.js">
  <style>
    .trivia-section {
      max-width: 720px;
      margin: 0 auto;
      padding: 6rem 1.5rem 3rem;
      text-align: center;
    }
    .trivia-section h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .trivia-section p {
      opacity: 0.7;
      margin-bottom: 2rem;
      font-size: 1rem;
    }
    .trivia-iframe-wrap {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
    }
    .trivia-iframe-wrap iframe {
      width: 100%;
      border: none;
      border-radius: 12px;
      min-height: 600px;
      transition: height 0.2s ease;
      background-color: {{ quiz.theme.bg }};
      overflow: hidden;
    }
    quiz-embed {
      display: block;
      width: 100%;
      border-radius: 12px;
      overflow: hidden;
      min-height: 600px;
    }
  </style>
{% endblock %}

{% block navScript %}
    nav.classList.add('scrolled');
{% endblock %}

{% block content %}
  <!-- ======== TRIVIA ======== -->
  <section class="trivia-section">
    <h1>{{ quiz.heading }}</h1>
    <p>{{ quiz.description | safe }}</p>

    <div class="trivia-iframe-wrap">
      <!-- Primary: Web Component (no iframe, no cross-origin issues) -->
      <quiz-embed
        id="quiz-wc"
        community="{{ quiz.community }}"
        bg="{{ quiz.theme.bg }}"
        surface="{{ quiz.theme.surface }}"
        primary="{{ quiz.theme.primary }}"
        accent="{{ quiz.theme.accent }}"
        text="{{ quiz.theme.text }}"
        font="{{ quiz.theme.font }}"
        count="{{ quiz.behavior.count }}"
        difficulty="{{ quiz.behavior.difficulty }}"
        timer="{{ quiz.behavior.timer }}"
        category="{{ quiz.behavior.category }}"
      ></quiz-embed>

      <!-- Fallback: iframe for browsers without custom element support -->
      <noscript>
        <iframe
          id="quiz-iframe"
          src="{{ quiz.embed_base_url }}?community={{ quiz.community }}&bg={{ quiz.theme.bg | urlencode }}&surface={{ quiz.theme.surface | urlencode }}&primary={{ quiz.theme.primary | urlencode }}&accent={{ quiz.theme.accent | urlencode }}&text={{ quiz.theme.text | urlencode }}&font={{ quiz.theme.font | urlencode }}&count={{ quiz.behavior.count }}&difficulty={{ quiz.behavior.difficulty }}&timer={{ quiz.behavior.timer }}&category={{ quiz.behavior.category }}"
          allowtransparency="true"
          scrolling="no"
          loading="lazy"
          title="{{ quiz.heading }}">
        </iframe>
      </noscript>
    </div>
  </section>
{% endblock %}
